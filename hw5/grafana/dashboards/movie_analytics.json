{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Retention Cohort Heatmap",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 },
              { "color": "dark-green", "value": 80 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cohort" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
          "queryType": "sql",
          "rawSql": "SELECT cohort_date AS Cohort, round(argMax(if(day_offset = 0, retention_rate, 0), computed_at), 1) AS `Day 0`, round(argMax(if(day_offset = 1, retention_rate, 0), computed_at), 1) AS `Day 1`, round(argMax(if(day_offset = 2, retention_rate, 0), computed_at), 1) AS `Day 2`, round(argMax(if(day_offset = 3, retention_rate, 0), computed_at), 1) AS `Day 3`, round(argMax(if(day_offset = 4, retention_rate, 0), computed_at), 1) AS `Day 4`, round(argMax(if(day_offset = 5, retention_rate, 0), computed_at), 1) AS `Day 5`, round(argMax(if(day_offset = 6, retention_rate, 0), computed_at), 1) AS `Day 6`, round(argMax(if(day_offset = 7, retention_rate, 0), computed_at), 1) AS `Day 7` FROM movie_analytics.daily_retention GROUP BY cohort_date ORDER BY cohort_date DESC LIMIT 30",
          "format": 2,
          "meta": {
            "builderOptions": {
              "mode": "list",
              "database": "movie_analytics",
              "table": "daily_retention"
            }
          },
          "refId": "A"
        }
      ]
    },
    {
      "title": "DAU (Daily Active Users)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
          "queryType": "sql",
          "rawSql": "SELECT event_date AS time, argMax(dau, computed_at) AS DAU FROM movie_analytics.daily_active_users GROUP BY event_date ORDER BY event_date",
          "format": 1,
          "meta": {
            "builderOptions": {
              "mode": "list",
              "database": "movie_analytics",
              "table": "daily_active_users"
            }
          },
          "refId": "A"
        }
      ]
    },
    {
      "title": "View Conversion Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
          "queryType": "sql",
          "rawSql": "SELECT event_date AS time, argMax(conversion_rate, computed_at) AS `Conversion %` FROM movie_analytics.daily_view_conversion GROUP BY event_date ORDER BY event_date",
          "format": 1,
          "meta": {
            "builderOptions": {
              "mode": "list",
              "database": "movie_analytics",
              "table": "daily_view_conversion"
            }
          },
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 10 Movies by Views",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
          "queryType": "sql",
          "rawSql": "SELECT movie_id AS Movie, sum(view_count) AS Views FROM movie_analytics.daily_top_movies GROUP BY movie_id ORDER BY Views DESC LIMIT 10",
          "format": 2,
          "meta": {
            "builderOptions": {
              "mode": "list",
              "database": "movie_analytics",
              "table": "daily_top_movies"
            }
          },
          "refId": "A"
        }
      ]
    },
    {
      "title": "Average View Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
          "queryType": "sql",
          "rawSql": "SELECT event_date AS time, argMax(avg_duration, computed_at) AS `Avg Duration` FROM movie_analytics.daily_avg_view_duration GROUP BY event_date ORDER BY event_date",
          "format": 1,
          "meta": {
            "builderOptions": {
              "mode": "list",
              "database": "movie_analytics",
              "table": "daily_avg_view_duration"
            }
          },
          "refId": "A"
        }
      ]
    },
    {
      "title": "Device Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-ds" },
          "queryType": "sql",
          "rawSql": "SELECT device_type AS Device, sum(user_count) AS Users FROM movie_analytics.daily_device_distribution GROUP BY device_type ORDER BY Users DESC",
          "format": 2,
          "meta": {
            "builderOptions": {
              "mode": "list",
              "database": "movie_analytics",
              "table": "daily_device_distribution"
            }
          },
          "refId": "A"
        }
      ]
    }
  ],
